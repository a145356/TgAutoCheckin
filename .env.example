# Telegram API Credentials
# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Your phone number (with country code, e.g., +1234567890)
PHONE_NUMBER=+1234567890

# Group IDs to send check-in messages (comma-separated)
# Use list_groups.py to find these IDs
GROUP_IDS=-1001234567890,-1009876543210

# Check-in message to send
CHECKIN_MESSAGE=签到

# Timezone for scheduling (default: Asia/Singapore)
TIMEZONE=Asia/Singapore

# Keywords to detect success in replies (comma-separated)
KEYWORDS=签到,成功,积分,获得
